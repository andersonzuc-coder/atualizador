<UserControl x:Class="Atualizador.Views.ConfiguracaoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.FontFamily>Segoe UI</UserControl.FontFamily>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Configurações" FontSize="18" FontWeight="Bold" Margin="4" Foreground="#222" />
        <TextBlock Grid.Row="0" Text="Ajuste os caminhos e credenciais usadas pelo aplicativo" FontSize="12" Margin="4,28,4,0" Foreground="#666" />

        <Border Grid.Row="1" Background="#FBFDFF" BorderBrush="#E6EDF8" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Pasta Raiz dos EXEs" VerticalAlignment="Center" Margin="4" FontWeight="SemiBold" Foreground="#333" />
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtPastaRaiz" Margin="4" Height="30" FontSize="13" ToolTip="Caminho onde os executáveis estão localizados" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Pasta Nuvem" VerticalAlignment="Center" Margin="4" FontWeight="SemiBold" Foreground="#333" />
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtNuvem" Margin="4" Height="30" FontSize="13" ToolTip="Pasta de destino na nuvem" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Senha" VerticalAlignment="Center" Margin="4" FontWeight="SemiBold" Foreground="#333" />
                <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="TxtSenha" Margin="4" Height="30" ToolTip="Senha usada para autenticação" />

                <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Salvar" x:Name="BtnSalvar" Click="BtnSalvar_Click" Width="120" Height="34" Margin="4" Background="#1976D2" Foreground="White" BorderBrush="#1976D2" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>