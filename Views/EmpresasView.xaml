<UserControl x:Class="Atualizador.Views.EmpresasView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- filtros -->
        <Border Grid.Row="0" Padding="8" Margin="0,0,0,8" Background="#FFF" CornerRadius="6" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left"  >
                <TextBlock Text="Empresa:" VerticalAlignment="Center" Margin="4" FontWeight="SemiBold"/>
                <ComboBox x:Name="CbEmpresa" Width="220" Margin="4" />

                <TextBlock Text="Regime Tributário:" VerticalAlignment="Center" Margin="12,4,4,4" FontWeight="SemiBold"/>
                <ComboBox x:Name="CbRegime" Width="200" Margin="4" />

                <TextBlock Text="Data Início:" VerticalAlignment="Center" Margin="12,4,4,4" FontWeight="SemiBold"/>
                <DatePicker x:Name="DpFrom" Width="140" Margin="4" />

                <TextBlock Text="Data Fim:" VerticalAlignment="Center" Margin="12,4,4,4" FontWeight="SemiBold"/>
                <DatePicker x:Name="DpTo" Width="140" Margin="4" />

                <Button x:Name="BtnAplicarFiltros" Content="Aplicar" Margin="12,4,4,4" Padding="8,4" Click="BtnAplicarFiltros_Click"/>
                <Button x:Name="BtnLimparFiltros" Content="Limpar" Margin="4" Padding="8,4" Click="BtnLimparFiltros_Click"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="GridClientes" AutoGenerateColumns="False" Grid.Row="1" SelectionChanged="GridClientes_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" FontSize="16"/>
                <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="1250" FontSize="16"  />

                <DataGridCheckBoxColumn Header="Admin" Binding="{Binding Admin}" />
                <DataGridCheckBoxColumn Header="Caixa" Binding="{Binding Caixa}" />
                <DataGridCheckBoxColumn Header="Copy" Binding="{Binding Copy}" />
                <DataGridCheckBoxColumn Header="Conect" Binding="{Binding Conect}" />
                <DataGridTextColumn Header="Regime_Tributario" Binding="{Binding Regime_Tributario}" />
                <DataGridTextColumn Header="Data" Binding="{Binding Data}" />
                
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Excluir" Height="36" Width="120" Margin="0,0,8,0" Click="BtnExcluir_Click" FontSize="14" />
            <Button Content="Atualizar" Height="36" Width="140" Click="BtnAtualizar_Click" FontSize="14" />
        </StackPanel>
    </Grid>
</UserControl>